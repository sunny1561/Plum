# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API key — required for real image/PDF extraction
# Get one at https://console.anthropic.com/
# All 12 test cases work WITHOUT this key (structured content bypasses the LLM call)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Path to the policy JSON file (auto-detected if not set)
POLICY_PATH=../../policy_terms.json

# Server settings
PORT=8000
HOST=0.0.0.0
